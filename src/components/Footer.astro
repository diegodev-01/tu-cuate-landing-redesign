---
import { Image } from "astro:assets";
import Logo from "../assets/logo_negro_bold.png";
---
<section class="bottom-hero-wrapper">
  <div class="bottom-hero-canvas">
    <div class="footer-content">
      <div class="brand-section">
        <Image src={Logo} alt="Logo Tu Cuate" class="footer-logo" />
        <p class="hero-description">
          Tu plataforma digital para revender y generar ingresos desde donde estés.
        </p>
        <div class="hero-buttons">
          <a href="#" class="btn-outline">Descarga la app</a>
        </div>
      </div>

      <div class="links-section">
        <div class="link-column">
          <h3>Contacto</h3>
          <a href="mailto:hola@tucuate.com">hola@tucuate.com</a>
          <a href="#">Soporte Técnico</a>
          <a href="#">WhatsApp</a>
        </div>
        <div class="link-column">
          <h3>Navegación</h3>
          <a href="#">Inicio</a>
          <a href="#">Puntos de recarga</a>
          <a href="#">Acerca de</a>
        </div>
        <div class="link-column">
          <h3>Legal</h3>
          <a href="#">Términos y Condiciones</a>
          <a href="#">Aviso de Privacidad</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Tu Cuate. Todos los derechos reservados.</p>
    </div>
  </div>
</section>

<style>
  .bottom-hero-wrapper {
    background-color: #fdfcf5; /* Mismo fondo de la página */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .bottom-hero-canvas {
    position: relative;
    /* Mismas proporciones del hero superior */
    width: calc(100vw - 100px);
    max-width: 100%;
    
    /* Mismo degradado morado */
    background: linear-gradient(
      135deg,
      #360c75 32%,
      rgba(54, 12, 117, 0.88) 60%,
      rgba(54, 12, 117, 0.74) 94%
    );
    
    /* Redondeadas para replicar el estilo de la forma del hero sin usar clip-path SVG */
    border-radius: 40px 40px 0 0;  
    
    padding: 4rem 5rem 3rem 5rem;
    display: flex;
    flex-direction: column;
    color: white;
    box-shadow: 0 20px 50px rgba(54, 12, 117, 0.15);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    gap: 4rem;
    flex-wrap: wrap;
    margin-bottom: 5rem;
  }

  .brand-section {
    flex: 1;
    min-width: 300px;
    max-width: 450px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer-logo {
    width: 280px;
    height: auto;
    filter: brightness(0) invert(1); /* Poner blanco el logo */
  }

  .hero-description {
    color: rgba(255, 255, 255, 0.95);
    font-size: 1.6rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .hero-buttons {
    display: flex;
    gap: 15px;
    margin-top: 15px;
  }

  .btn-outline {
    width: 200px;
    height: 45px;
    border-radius: 10em;
    background: #de3b62; /* Pink de Tu Cuate */
    transition: background 0.2s, transform 0.2s;
    text-decoration: none;
    color: white;
    display: flex;
    justify-content: center;
    align-items: center;
    font-weight: bold;
    font-size: 1.1rem;
  }

  .btn-outline:hover {
    background: #be2e51;
    transform: translateY(-2px);
  }

  .links-section {
    display: flex;
    gap: 5rem;
    flex-wrap: wrap;
    padding-top: 1rem;
  }

  .link-column {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .link-column h3 {
    font-size: 1.6rem;
    color: #dc9b32; /* Naranja de Tu Cuate */
    margin-bottom: 0.8rem;
    font-weight: bold;
  }

  .link-column a {
    color: white;
    text-decoration: none;
    font-size: 1.25rem;
    transition: color 0.2s, padding-left 0.2s;
    opacity: 0.9;
  }

  .link-column a:hover {
    color: #de3b62; /* Hover rosa */
    opacity: 1;
    padding-left: 5px; /* Animación sutil */
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 2rem;
    text-align: center;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .bottom-hero-wrapper {
      padding: 0; /* En móvil abarca todo el ancho como el hero principal */
    }

    .bottom-hero-canvas {
      width: 100vw;
      border-radius: 0;
      padding: 4rem 2rem 2rem 2rem;
    }

    .footer-content {
      flex-direction: column;
      gap: 3.5rem;
      margin-bottom: 3.5rem;
    }

    .brand-section {
      align-items: center;
      text-align: center;
    }

    .footer-logo {
      width: 240px;
    }

    .links-section {
      flex-direction: column;
      gap: 3rem;
      text-align: center;
      width: 100%;
    }
  }
</style>
