---

<section class="ventajas-section" id="ventajas">
  <div class="contenedor">
    <h2 class="titulo">¿Por qué elegir <span class="destacado">Tu Cuate</span>?</h2>
    
    <div class="grid-ventajas" id="ventajas-grid">
      <div class="tarjeta-ventaja card-purple">
        <div class="icono">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/><path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4h-4z"/></svg>
        </div>
        <p class="texto">100% gratis</p>
      </div>

      <div class="tarjeta-ventaja card-pink">
        <div class="icono">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"></line><circle cx="6.5" cy="6.5" r="2.5"></circle><circle cx="17.5" cy="17.5" r="2.5"></circle></svg>
        </div>
        <p class="texto">Comisiones hasta 10%</p>
      </div>

      <div class="tarjeta-ventaja card-orange">
        <div class="icono">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"></rect><circle cx="12" cy="12" r="2"></circle><path d="M6 12h.01M18 12h.01"/></svg>
        </div>
        <p class="texto">Retira tus ganancias cuando quieras</p>
      </div>

      <div class="tarjeta-ventaja card-dark">
        <div class="icono">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
        </div>
        <p class="texto">¡Solo necesitas tu número de celular!</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Animación de entrada en scroll para las tarjetas
  const cards = document.querySelectorAll('.tarjeta-ventaja');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        // Opcional: Desconectar después de animar para que solo ocurra una vez
        // observer.unobserve(entry.target); 
      }
    });
  }, {
    threshold: 0.4
  });

  cards.forEach((card, index) => {
    // Añadimos un pequeño delay escalonado basado en el índice
    card.setAttribute('style', `--delay: ${index * 0.15}s`);
    observer.observe(card);
  });
</script>

<style>
  .ventajas-section {
    padding: 6rem 1.5rem;
    background-color: #fdfcf5; /* Match global background */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .contenedor {
    max-width: 1200px;
    width: 100%;
  }

  .titulo {
    font-size: clamp(2.5rem, 5vw, 3.8rem);
    text-align: center;
    margin-bottom: 4rem;
    color: #111827;
    font-weight: bold;
    letter-spacing: -0.02em;
  }

  .destacado {
    color: #de3b62; /* Pink de la marca */
    position: relative;
    display: inline-block;
  }

  .destacado::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 100%;
    height: 6px;
    background-color: #dc9b32; /* Orange de la marca */
    border-radius: 4px;
    z-index: -1;
  }

  .grid-ventajas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2.5rem;
  }

  .tarjeta-ventaja {
    background-color: #ffffff;
    border-radius: 2.5rem;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
    border: 2px solid #f0f0f0;
    
    /* Animación de entrada inicial (oculto) */
    opacity: 0;
    transform: translateY(40px);
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                opacity 0.6s ease,
                box-shadow 0.3s ease,
                border-color 0.3s ease;
    transition-delay: var(--delay, 0s);
  }

  /* Clase que añade JS cuando entra en vista */
  .tarjeta-ventaja.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .tarjeta-ventaja:hover {
    transform: translateY(-10px) !important;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08);
    transition-delay: 0s; /* Quitamos delay en el hover */
  }

  .icono {
    width: 85px;
    height: 85px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 2rem;
    transition: transform 0.3s ease;
  }

  .tarjeta-ventaja:hover .icono {
    transform: scale(1.1) rotate(5deg);
  }

  .icono svg {
    width: 42px;
    height: 42px;
  }

  .texto {
    font-size: 1.6rem;
    font-weight: bold;
    color: #111827;
    line-height: 1.3;
    margin: 0;
  }

  /* ── Estilos Específicos por Tarjeta (Identidad de Marca) ── */
  
  /* Morado */
  .card-purple:hover {
    border-color: #360c75;
  }
  .card-purple .icono {
    background-color: rgba(54, 12, 117, 0.08);
    color: #360c75;
  }

  /* Rosa */
  .card-pink:hover {
    border-color: #de3b62;
  }
  .card-pink .icono {
    background-color: rgba(222, 59, 98, 0.08);
    color: #de3b62;
  }

  /* Naranja */
  .card-orange:hover {
    border-color: #dc9b32;
  }
  .card-orange .icono {
    background-color: rgba(220, 155, 50, 0.08);
    color: #dc9b32;
  }

  /* Negro / Dark */
  .card-dark:hover {
    border-color: #000000;
  }
  .card-dark .icono {
    background-color: rgba(0, 0, 0, 0.06);
    color: #000000;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .ventajas-section {
      padding: 4rem 1.5rem;
    }
    
    .titulo {
      font-size: 2.5rem;
      margin-bottom: 3rem;
    }
    
    .tarjeta-ventaja {
      padding: 2.5rem 1.5rem;
      border-radius: 2rem;
    }
    
    .texto {
      font-size: 1.4rem;
    }
    
    .icono {
      width: 70px;
      height: 70px;
      margin-bottom: 1.5rem;
    }
    
    .icono svg {
      width: 34px;
      height: 34px;
    }
  }
</style>
