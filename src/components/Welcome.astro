---
import { Image } from "astro:assets";

import Iso from "../assets/iso_negro_bold.png";
import Logo from "../assets/logo_negro_bold.png";
import Hand from "../assets/mobile-hand.png";
import Pet from "../assets/pet-tucuate.png";
import PhoneImage from "../assets/phone-image.jpeg";
---

<section class="hero-section" id="inicio">
  <div class="canvas">
  <!-- El SVG ahora tiene una clase específica para ocultarlo en móviles -->
  <svg
    class="shape-background desktop-only"
    viewBox="0 0 800 500"
    preserveAspectRatio="none"
  >
    <defs>
      <linearGradient id="purpleGradient" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="32.32%" stop-color="#360c75"></stop>
        <stop offset="60.19%" stop-color="#360c75" stop-opacity="0.88"></stop>
        <stop offset="93.99%" stop-color="#360c75" stop-opacity="0.74"></stop>
      </linearGradient>

      <clipPath id="svgClip" clipPathUnits="objectBoundingBox">
        <path
          transform="scale(0.00125, 0.002)"
          d="
            M 120 20 
            H 760 A 20 20 0 0 1 780 40 
            V 360 A 20 20 0 0 1 760 380 
            H 640 A 20 20 0 0 0 620 400 
            V 460 A 20 20 0 0 1 600 480 
            H 420 A 20 20 0 0 1 400 460 
            V 400 A 20 20 0 0 0 380 380 
            H 40 A 20 20 0 0 1 20 360 
            V 80 A 20 20 0 0 1 40 60 
            H 80 A 20 20 0 0 0 100 40 
            A 20 20 0 0 1 120 20 
            Z"
        ></path>
      </clipPath>
    </defs>

    <path
      d="
        M 120 20 
        H 760 A 20 20 0 0 1 780 40 
        V 360 A 20 20 0 0 1 760 380 
        H 640 A 20 20 0 0 0 620 400 
        V 460 A 20 20 0 0 1 600 480 
        H 420 A 20 20 0 0 1 400 460 
        V 400 A 20 20 0 0 0 380 380 
        H 40 A 20 20 0 0 1 20 360 
        V 80 A 20 20 0 0 1 40 60 
        H 80 A 20 20 0 0 0 100 40 
        A 20 20 0 0 1 120 20 
        Z"
      class="shape-path"
      stroke-width="1"
      stroke-linejoin="round"
      vector-effect="non-scaling-stroke"
    >
    </path>
  </svg>

  <div class="content-wrapper">
    <!-- Oculto en móviles también -->
    <div class="clipped-content desktop-only">
      <div class="hand-wrapper">
		  <Image src={Hand} alt="Mano con celular" class="hand" />
      </div>
    </div>

    <div class="ui-elements">
      <Image src={Iso} alt="Iso Tu Cuate" class="iso" />

      <!-- Menú Hamburguesa con CSS Puro -->
      <input type="checkbox" id="menu-toggle" class="menu-checkbox" />
      <label for="menu-toggle" class="hamburger">
        <span></span>
        <span></span>
        <span></span>
      </label>

      <nav class="nav">
        <a class="nav-link" href="#inicio">Inicio</a>
        <a class="nav-link" href="#acerca-de">Acerca de</a>
        <a class="nav-link" href="#ventajas">Ventajas</a>
        <a class="nav-link" href="#entregas">Nuestros Servicios</a>
        <a class="nav-link" href="#contacto">Contacto</a>
      </nav>

      <div class="pill pill-orange desktop-only">
        <a href="#puntos-recarga" class="pill-link">Puntos de recarga</a>
      </div>
    </div>

    <div class="hero-content">
      <Image src={Logo} alt="Logo Grande Tu Cuate" class="hero-logo" />
      <p class="hero-description">
        Tu plataforma digital para revender y generar ingresos desde donde
        estés.
      </p>
      <div class="hero-buttons">
        <a href="#" class="btn-outline">Descarga la app</a>
        <a href="#" class="btn-outline">Accede a la web</a>
      </div>
    </div>
    <Image src={Pet} alt="Mascota Tu Cuate" class="pet" />

    <p class="branding">
      Desliza y descubre mas de
      <Image src={Logo} alt="Logo Tu Cuate" class="logo" />
    </p>
    <p class="slogan">Recarga, crece y comparte</p>
  </div>
</div>
</section>

<script>
  window.addEventListener('scroll', () => {
    // Parallax para la mano
    const hand = document.querySelector<HTMLElement>('.hand-wrapper');
    if (hand && window.innerWidth > 768) {
      const scrollY = window.scrollY;
      hand.style.transform = `translateY(${scrollY * 0.3}px)`;
    }

    // Navbar sticky
    const uiElements = document.querySelector('.ui-elements');
    if (uiElements) {
      if (window.scrollY > 80) {
        uiElements.classList.add('sticky');
      } else {
        uiElements.classList.remove('sticky');
      }
    }
  });

  // Cerrar menú móvil al hacer click
  const menuCheckbox = document.getElementById('menu-toggle') as HTMLInputElement;
  const navLinks = document.querySelectorAll('.nav-link');
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (menuCheckbox) menuCheckbox.checked = false;
    });
  });
</script>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .hero-section {
    background-color: #fdfcf5;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
  }

  .canvas {
    position: relative;
    width: calc(100vw - 100px);
    height: calc(100vh - 1px);
    max-width: 100%;
    max-height: 100%;
    overflow: hidden;
  }

  .shape-path {
    fill: url(#purpleGradient);
    stroke: #000;
  }

  .shape-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .content-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    padding: 20px;
    display: flex;
    flex-direction: column;
  }

  .clipped-content {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    clip-path: url(#svgClip);
    pointer-events: none;
  }

  .ui-elements {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 15px;
    padding: 0 40px;
    z-index: 200;
    transition: all 0.3s ease;
  }

  .ui-elements.sticky {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: 80vw;
    height: 60px;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border-radius: 100px;
    z-index: 1000;
    margin-top: 0;
    padding: 0 10px;
  }

  .ui-elements.sticky .nav {
    position: static;
    width: auto;
    flex: 1;
    justify-content: center;
    gap: 20px;
    background-color: transparent;
    margin: 0 20px;
  }

  .ui-elements.sticky .iso {
    position: static;
    width: 100px;
    margin-left: 10px;
  }

  .ui-elements.sticky .pill-orange {
    position: static;
    width: 12em;
    margin-right: 10px;
  }

  /* Control de visibilidad del menú hamburguesa */
  .menu-checkbox {
    display: none;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 6px;
    cursor: pointer;
    padding: 10px;
  }

  .hamburger span {
    display: block;
    width: 30px;
    height: 3px;
    background-color: #000;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hand-wrapper {
    position: absolute;
    right: 4.5%;
    bottom: 10%;
    width: 50em;
    height: auto;
    z-index: 100;
  }

  .hand {
    position: relative;
    width: 100%;
    height: auto;
    z-index: 2;
    pointer-events: none;
  }

  .phone-screen {
    position: absolute;
    top: 5.5%;
    left: 23.5%;
    width: 48.5%;
    height: 74%;
	padding: 4em 7em;
    border-radius: 2em; /* Bordes redondeados de la pantalla */
    z-index: 10; /* Va detrás de la imagen de la mano (asumiendo fondo transparente) */
    object-fit: cover;
  }

  .nav {
    position: absolute;
    top: 2em;
    left: 15%;
    width: 40em;
    height: 40px;
    border-radius: 100px;
    background-color: white;
    display: flex;
    justify-content: space-around;
    align-items: center;
    transition: all 0.3s ease;
  }

  .nav-link {
    font-size: 1.2em;
    font-weight: 500;
    color: black;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .nav-link:hover {
    color: #de3b62;
  }

  .iso {
    position: absolute;
    top: 1em;
    left: 4%;
    width: 120px;
    height: auto;
    transition: all 0.3s ease;
  }

  .pet {
    display: none;
  }

  .branding {
    position: absolute;
    bottom: 50px;
    right: 5%;
    font-size: 1.5em;
    width: 300px;
    font-weight: 500;
    color: black;
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    letter-spacing: 0.5px;
  }

  .slogan {
    position: absolute;
    bottom: 0.5em;
    left: 5%;
    font-size: 4em;
    width: 600px;
    font-weight: 400;
    color: black;
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    letter-spacing: 0.5px;
  }

  .logo {
    width: 150px;
    height: auto;
    display: inline-block;
    vertical-align: middle;
  }

  .pill-orange {
    position: absolute;
    top: 2em;
    right: 4%;
    width: 10em;
    height: 40px;
    border-radius: 100px;
    background-color: #dc9b32;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.3s ease;
  }

  .pill-link {
    font-size: 1em;
    font-weight: 500;
    color: white;
    text-decoration: none;
  }

  .hero-content {
    position: absolute;
    top: 30%;
    left: 8%;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    z-index: 5;
  }

  .hero-logo {
    width: 600px;
    height: auto;
    filter: brightness(0) invert(1);
  }

  .hero-description {
    color: #ffffff;
    font-size: 2em;
    font-weight: 500;
    line-height: 1.4;
  }

  .hero-buttons {
    display: flex;
    gap: 15px;
    margin-top: 5px;
  }

  .btn-outline {
    width: 180px;
    height: 40px;
    border-radius: 10em;
    background: #de3b62;
    transition: background 0.2s;
    text-decoration: none;
    color: white;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .btn-outline:hover {
    background: #be2e51;
  }

  .mobile-only {
    display: none;
  }

  /* ==========================================================================
     MEDIA QUERY: MÓVILES Y TABLETAS (Responsive)
     ========================================================================== */
  @media (max-width: 768px) {
    .desktop-only {
      display: none !important;
    }

    .mobile-only {
      display: block;
    }

    .pet {
      display: block;
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 80vw;
      height: auto;
      z-index: 100;
    }
    .canvas {
      width: 100vw;
      height: 100vh;
      background: linear-gradient(
        135deg,
        #360c75 32%,
        rgba(54, 12, 117, 0.88) 60%,
        rgba(54, 12, 117, 0.74) 94%
      );
      display: flex;
      flex-direction: column;
    }

    .content-wrapper {
      position: relative;
      padding: 20px;
      height: 100%;
      justify-content: space-between;
    }

    .ui-elements {
      position: relative;
      width: 100%;
      height: auto;
      padding: 0;
      margin-top: 5px;
      background-color: transparent;
      border-radius: 0;
      top: auto;
      left: auto;
      transform: none;
    }
    
    .ui-elements.sticky {
      position: fixed;
      top: 10px;
      left: 50%;
      transform: translateX(-50%);
      width: 90vw;
      padding: 10px 20px;
      border-radius: 100px;
      background-color: rgba(54, 12, 117, 0.95);
      z-index: 1000;
    }

    .ui-elements.sticky .iso {
      filter: brightness(0) invert(1);
      position: static;
      margin: 0;
    }

    .iso {
      position: static;
      width: 90px;
      /* Invertimos el color para que contraste con el fondo morado */
      filter: brightness(0) invert(1);
    }

    /* Activación del botón Hamburguesa */
    .hamburger {
      display: flex;
      position: relative;
      z-index: 210;
    }

    /* Cambiar color de hamburguesa a blanco por el fondo oscuro */
    .hamburger span {
      background-color: #fff;
    }

    /* Comportamiento del menú desplegable móvil */
    .nav {
      position: fixed;
      top: 0;
      left: 100%;
      width: 100vw;
      height: 100vh;
      border-radius: 0;
      background-color: #360c75;
      flex-direction: column;
      justify-content: center;
      gap: 30px;
      transition: left 0.4s cubic-bezier(0.77, 0.2, 0.05, 1);
      z-index: 200;
      margin: 0;
    }

    /* Evitar que los estilos del header sticky rompan el menú en móvil */
    .ui-elements.sticky .nav {
      position: absolute;
      top: -10px;
      left: 100vw;
      width: 100vw;
      height: 100vh;
      background-color: #360c75;
      margin: 0;
      flex-direction: column;
      justify-content: center;
      gap: 30px;
    }

    .ui-elements.sticky .menu-checkbox:checked ~ .nav {
      left: -5vw;
    }

    .nav-link {
      color: #fff;
      font-size: 1.8em;
    }

    .menu-pill {
      background-color: #dc9b32;
      padding: 12px 30px;
      border-radius: 30px;
      font-size: 1.2em;
    }

    /* Animación e Interacción de apertura de menú */
    .menu-checkbox:checked ~ .nav {
      left: 0;
    }

    .menu-checkbox:checked ~ .hamburger span:nth-child(1) {
      transform: translateY(9px) rotate(45deg);
    }

    .menu-checkbox:checked ~ .hamburger span:nth-child(2) {
      opacity: 0;
    }

    .menu-checkbox:checked ~ .hamburger span:nth-child(3) {
      transform: translateY(-9px) rotate(-45deg);
    }

    /* Ajustes de contenido Hero */
    .hero-content {
      position: static;
      margin-top: 60px;
      max-width: 100%;
      align-items: center;
      text-align: center;
      gap: 25px;
    }

    .hero-logo {
      width: 85%;
      max-width: 340px;
    }

    .hero-description {
      font-size: 1.2em;
      padding: 0 10px;
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
      align-items: center;
      gap: 12px;
    }

    .btn-outline {
      width: 80%;
      max-width: 280px;
      height: 45px;
    }

    /* Adaptación de Textos Inferiores */
    .branding {
      position: static;
      width: 100%;
      justify-content: center;
      color: #fff;
      font-size: 1em;
      margin-top: auto;
      padding-top: 30px;
    }

    .branding .logo {
      width: 100px;
      filter: brightness(0) invert(1);
    }

    .slogan {
      display: none;
      position: static;
      width: 100%;
      text-align: center;
      justify-content: center;
      color: #fff;
      font-size: 1.5em;
      margin-top: 10px;
      padding-bottom: 10px;
    }
  }
</style>
